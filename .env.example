# Copy to .env and fill values, or run: ./scripts/fetch_secrets.sh
WORK_ROOT=/opt/work
SITES_YAML=/opt/work/sites.yaml
PORT=8090

GOOGLE_APPLICATION_CREDENTIALS=secrets/firebase-key.json
GOOGLE_PLACES_API_KEY=
KRCAMPUS_GOOGLE_MAPS_API_KEY=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FLASK_SECRET_KEY=
ALLOWED_EMAILS=your@email.com

# Work Hub pipeline — per run: guide 3, content 6 (see content_pipeline.DEFAULT_*_LIMIT)
# CONTENT_LIMIT=6
# GUIDE_LIMIT=3
# krcampus: JA는 기본 run에서 제외 (EN 1 + JA 1 call/item). JA 포함 시:
# CONTENT_PIPELINE_WITH_JA=1

# GSC SEO 작업 (Gemini)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-latest
# GEMINI_BUDGET_YEN=7000
# IMAGEN_BUDGET_YEN=120
# IMAGEN_UNIT_YEN=15

# GSC API (Search Console) — gsc-token.json = OAuth 클라이언트, 아래는 사용자 토큰
GSC_CLIENT_SECRETS=gsc-token.json
GSC_TOKEN_PATH=gsc-oauth-user.json

# Local only (8090 OAuth redirect 미등록 시 1 권장)
LOCAL_DEV_AUTH=1
DEV_LOGIN_EMAIL=your@email.com
