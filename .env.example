# Copy to .env and fill values, or run: ./scripts/fetch_secrets.sh
WORK_ROOT=/opt/work
SITES_YAML=/opt/work/sites.yaml
PORT=8090

GOOGLE_APPLICATION_CREDENTIALS=secrets/firebase-key.json
GOOGLE_PLACES_API_KEY=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FLASK_SECRET_KEY=
ALLOWED_EMAILS=your@email.com

# GSC SEO 작업 (Gemini)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-latest

# GSC API (Search Console) — gsc-token.json = OAuth 클라이언트, 아래는 사용자 토큰
GSC_CLIENT_SECRETS=gsc-token.json
GSC_TOKEN_PATH=gsc-oauth-user.json

# Local only (8090 OAuth redirect 미등록 시 1 권장)
LOCAL_DEV_AUTH=1
DEV_LOGIN_EMAIL=your@email.com
